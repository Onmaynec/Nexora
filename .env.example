# Server network
HOST=0.0.0.0
PORT=3443
HTTP_PORT=3080
NEXORA_TLS=true
NEXORA_HTTP_REDIRECT=true

# Nexora Pulse: disabled | sandbox | production
NEXORA_PULSE_MODE=disabled
# Required only for production:
# NEXORA_PULSE_CLOUD_URL=https://billing.example.com
# NEXORA_PULSE_API_KEY=replace-with-server-scoped-secret
# NEXORA_PULSE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...-----END PUBLIC KEY-----

# Optional generic update feeds. Client defaults to public Onmaynec/Nexora releases.
# NEXORA_CLIENT_UPDATE_URL=https://updates.example.com/nexora/client
# NEXORA_SERVER_UPDATE_URL=https://updates.example.com/nexora/server
# NEXORA_GITHUB_OWNER=Onmaynec
# NEXORA_GITHUB_REPO=Nexora
