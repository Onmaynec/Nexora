# Pulse Cloud public configuration
HOST=127.0.0.1
PORT=4545
CLOUD_PUBLIC_URL=https://pulse.example.com
PULSE_DATABASE_FILE=./data/pulse-cloud.sqlite
PAYMENT_PROVIDER=stripe
NEXORA_PULSE_SERVER_ID=
NEXORA_BILLING_CURRENCY=EUR
NEXORA_BILLING_REGION=FI
NEXORA_BILLING_TAX_MODE=exclusive
CLOUD_TRUST_PROXY=1
CLOUD_RATE_LIMIT_PER_MINUTE=180

# Local Server -> Pulse Cloud
NEXORA_PULSE_MODE=production
NEXORA_PULSE_CLOUD_URL=https://pulse.example.com
NEXORA_PULSE_API_KEY=
NEXORA_PULSE_PUBLIC_KEY_ID=
NEXORA_PULSE_PUBLIC_KEY=
NEXORA_PULSE_PUBLIC_KEYS_JSON=
NEXORA_PULSE_TIMEOUT_MS=8000
NEXORA_PULSE_SYNC_INTERVAL_MS=15000

# Server/operator credential — generate an independent high-entropy value
CLOUD_ADMIN_API_KEY=

# Stripe secret values
PAYMENT_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=
STRIPE_PLUS_PRICE_ID=
NEXORA_PLUS_PRICE_MINOR=
STRIPE_IMPULSE_500_PRICE_ID=
NEXORA_IMPULSE_500_PRICE_MINOR=

# Ed25519 signing keys. Private key exists only in Pulse Cloud.
ENTITLEMENT_SIGNING_KEY_ID=
ENTITLEMENT_SIGNING_PRIVATE_KEY=
ENTITLEMENT_SIGNING_PUBLIC_KEY=

# Cloud Identity
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
IDENTITY_ENCRYPTION_KEY=
NEXORA_PULSE_REDIRECT_URIS_JSON=["https://localhost:3443/?pulse-link-callback=1","nexora://cloud-account/complete"]
# Only for isolated automated tests. Never enable in production.
IDENTITY_EXPOSE_VERIFICATION_TOKENS=false

# Transactional email delivery endpoint. Must use HTTPS.
CLOUD_EMAIL_DELIVERY_URL=https://mail.example.com/v1/send
CLOUD_EMAIL_DELIVERY_API_KEY=

# Optional signed event sink for operations/reconciliation telemetry
CLOUD_EVENT_SINK_URL=
CLOUD_EVENT_SINK_SECRET=

# Worker controls
CLOUD_WORKER_INTERVAL_MS=10000
CLOUD_WORKER_LEASE_MS=30000
CLOUD_WORKER_TIMEOUT_MS=8000
